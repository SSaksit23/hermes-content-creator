# Copy this file to `.env` and fill in real values.
# This file is read by `docker compose` — never committed to git.

# Active LLM provider used by the backend proxy: "openai" (default) or "gemini".
LLM_PROVIDER=openai

# REQUIRED when LLM_PROVIDER=openai. Never shipped to the browser.
OPENAI_API_KEY=
# Override the OpenAI model (default: gpt-5.4-mini).
OPENAI_MODEL=gpt-5.4-mini

# REQUIRED when using RAG/web-search with the OpenAI driver. The proxy uses
# Tavily (https://tavily.com) instead of OpenAI's built-in web_search tool.
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=advanced
TAVILY_MAX_RESULTS=8

# REQUIRED only when LLM_PROVIDER=gemini.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Host port mappings (optional, defaults shown)
APP_PORT=3001
DEV_PORT=3001

# Optional: allowed origins for CORS, comma-separated. Leave blank when the
# frontend and API share an origin (the default with nginx).
# Example: CORS_ORIGINS=http://localhost:3001,https://my-app.example.com
CORS_ORIGINS=
